{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["topoDiscovery"],
  "properties": {
    "topoDiscovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scaleUp", "scaleOut", "storage"],
      "properties": {
        "scaleUp": {
          "$ref": "#/definitions/scaleUpDiscovery"
        },
        "scaleOut": {
          "$ref": "#/definitions/scaleOutDiscovery"
        },
        "storage": {
          "$ref": "#/definitions/storageDiscovery"
        }
      }
    },
    "switchSubscription": {
      "type": "object",
      "required": ["defaultGrpcPort", "ignorePortPatterns", "mtls"],
      "properties": {
        "defaultGrpcPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "ignorePortPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mtls": {
          "type": "object",
          "required": ["mode", "controllerSecretName", "switchAgentSecretName"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["auto", "existing", "disabled"]
            },
            "controllerSecretName": {
              "type": "string"
            },
            "switchAgentSecretName": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "label": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyTemplate"],
      "properties": {
        "keyTemplate": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scaleUpDiscovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "label"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["nv-topograph", "manual"]
        },
        "label": {
          "$ref": "#/definitions/label"
        }
      }
    },
    "scaleOutDiscovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "label"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["nv-topograph", "unifabric-roce"]
        },
        "label": {
          "$ref": "#/definitions/label"
        }
      }
    },
    "storageDiscovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "label"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["unifabric-roce", "unifabric-ib"]
        },
        "label": {
          "$ref": "#/definitions/label"
        }
      }
    }
  }
}
