                      "rawSql": "WITH splitByChar('/', '${workload}') AS w\nSELECT\n    $__timeInterval(time_flow_start) AS time,\n    IPv4NumToString(reinterpretAsUInt32(reverse(substring(sampler_address, 13, 4)))) AS switch,\n    sum(bytes * if(sampling_rate = 0, toUInt64(1), sampling_rate)) AS tx_bytes\nFROM flows_raw\nWHERE $__timeFilter(time_flow_start)\n  AND src_k8s_top_owner_namespace = w[1]\n  AND src_k8s_top_owner_kind = w[2]\n  AND src_k8s_top_owner_name = w[3]\nGROUP BY time, switch\nORDER BY time ASC"
