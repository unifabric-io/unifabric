                      "pluginVersion": "4.17.0",
                      "queryType": "table",
                      "rawSql": "WITH splitByChar('/', '${workload}') AS w\nSELECT countDistinct(pod) AS pods\nFROM\n(\n    SELECT src_k8s_pod_name AS pod\n    FROM flows_raw\n    WHERE $__timeFilter(time_flow_start)\n      AND src_k8s_top_owner_namespace = w[1]\n      AND src_k8s_top_owner_kind = w[2]\n      AND src_k8s_top_owner_name = w[3]\n      AND src_k8s_pod_name != ''\n\n    UNION DISTINCT\n\n    SELECT dst_k8s_pod_name AS pod\n    FROM flows_raw\n    WHERE $__timeFilter(time_flow_start)\n      AND dst_k8s_top_owner_namespace = w[1]\n      AND dst_k8s_top_owner_kind = w[2]\n      AND dst_k8s_top_owner_name = w[3]\n      AND dst_k8s_pod_name != ''\n)"
                    },
