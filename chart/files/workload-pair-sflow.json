          "pluginVersion": "4.17.0",
          "queryType": "timeseries",
          "rawSql": "WITH\n    splitByChar('/', '${src_workload}') AS src,\n    splitByChar('/', '${dst_workload}') AS dst\nSELECT\n    $__timeInterval(f.time_flow_start) AS time,\n    IPv4NumToString(reinterpretAsUInt32(reverse(substring(f.sampler_address, 13, 4)))) AS switch,\n    sum(f.bytes * if(f.sampling_rate = 0, toUInt64(1), f.sampling_rate)) / greatest(toFloat64($__interval_ms) / 1000.0, 1.0) AS rate\nFROM flows_raw AS f\nWHERE $__timeFilter(f.time_flow_start)\n  AND f.src_k8s_top_owner_namespace = src[1]\n  AND f.src_k8s_top_owner_kind = src[2]\n  AND f.src_k8s_top_owner_name = src[3]\n  AND f.dst_k8s_top_owner_namespace = dst[1]\n  AND f.dst_k8s_top_owner_kind = dst[2]\n  AND f.dst_k8s_top_owner_name = dst[3]\nGROUP BY time, switch\nORDER BY time ASC",
          "datasource": "${clickhouse}",
          "refId": "A"
        }
      ],
      "title": "src to dst by Switch",
